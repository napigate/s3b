# Docker image used as the Python base during build.
PYTHON_IMAGE=python:3.12-alpine

# Host port exposed by Docker Compose.
S3B_HOST_PORT=8088

# Port used by the app inside the container.
S3B_APP_PORT=8080

# Host path mounted as persistent runtime data.
S3B_DATA_PATH=./data

# Numeric host user/group used by the container to avoid local permission drift.
CURRENT_USER=1000
CURRENT_GROUP=1000

# Runtime settings passed into the container.
S3B_HOST=0.0.0.0
S3B_DATA_DIR=/data
